{
  "version": 2,
  "outputDirectory": ".",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/leaders", "dest": "/leaders.html" },
    { "src": "/gallery", "dest": "/gallery.html" },
    { "src": "/mission", "dest": "/mission.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}